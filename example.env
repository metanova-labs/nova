# General configs
SUBTENSOR_NETWORK="ws://localhost:9944" # or your chosen node
DEVICE_OVERRIDE="cpu" # None to run on GPU

# GitHub authentication
GITHUB_TOKEN="your_personal_access_token"

# GitHub configs - FOR MINERS
GITHUB_REPO_NAME="repo-name"
GITHUB_REPO_BRANCH="repo-branch"
GITHUB_REPO_OWNER="repo-owner"
GITHUB_REPO_PATH="" # path within repo or ""

# For validators
VALIDATOR_API_KEY="your_api_key"
# Set AUTO_UPDATE=1 to opt into the Compose + Watchtower auto-update flow:
# the validator starts the readiness HTTP server (/ready_to_update, /healthz), which
# scripts/pre-update.sh probes before each Watchtower rollout.
AUTO_UPDATE="0"

# Watchtower (nickfedor/watchtower) — Shoutrrr notification URL when --notifications shoutrrr is enabled.
# Format depends on target (Discord, Slack, etc.): https://containrrr.dev/shoutrrr/v0.8/services/overview/
WATCHTOWER_NOTIFICATION_URL=""
